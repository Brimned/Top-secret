        CFG.jitterAmt = 0.3
        CFG.opacity = 0
        CFG.aimGate = true
        CFG.aimFOV = 25
        for k in pairs(CFG.parts) do CFG.parts[k] = false end
        CFG.parts.HumanoidRootPart = true
        pState = {}; scPl = {}
