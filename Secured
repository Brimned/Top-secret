local function mkTog(gb,pname,flag,def)
    gb:AddToggle(flag,{Text=pname,Default=def or false,
        Callback=function(v)
            CFG.parts[pname]=v
            if not v then
                for _,p in ipairs(Players:GetPlayers()) do
                    if p~=LP and p.Character then
                        local pt=p.Character:FindFirstChild(pname)
                        if pt and origSz[pt] then restorePart(pt) end
                    end
                end
            end
        end})
end

