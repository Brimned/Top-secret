local function applyPreset(sz, jit, partSet, col, name, tip)
    CFG.size    = sz
    CFG.jitter  = jit
    CFG.opacity = 0
    if partSet then
        for k in pairs(CFG.parts) do CFG.parts[k] = false end
        for _, k in ipairs(partSet) do CFG.parts[k] = true end
    end
    if col then
        CFG.color   = col
        CFG.rainbow = false
        for part in pairs(origSz) do
            if part and part.Parent then pcall(function() part.Color = CFG.color end) end
        end
        refreshBoxColors()
    end
    pStyle = {}; scPl = {}
    pcall(function() Options.hitboxColor:SetValueRGB(CFG.color) end)
    local f = baseF()
    table.insert(f, { name="Preset", value=name,      inline=true })
    table.insert(f, { name="Size",   value=sz.."s",   inline=true })
    log("Preset: " .. name, tip, f, 16753920)
    Lib:Notify(name .. " — " .. tip, 3)
end

