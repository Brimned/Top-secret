local function teammate(p)
    if not CFG.teamSkip or not LP.Team then return false end
    return p.Team~=nil and p.Team==LP.Team
end

local function inAim(p)
    if not CFG.aimGate or not p.Character then return true end
    local hrp=p.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local sp,vis=Camera:WorldToViewportPoint(hrp.Position)
    if not vis then return false end
    return (Vector2.new(sp.X,sp.Y)-Camera.ViewportSize/2).Magnitude
        <=(CFG.aimFOV/Camera.FieldOfView)*Camera.ViewportSize.Y
end

local SKIP={Accessory=true,Hat=true,Tool=true,Fire=true,Smoke=true,
    Sparkles=true,SelectionBox=true,BillboardGui=true,SurfaceGui=true}
local SKIP_NAMES={Handle=true,HatAttachment=true,["Body Colors"]=true,
    Shirt=true,Pants=true,["Shirt Graphic"]=true,CharacterMesh=true,BodyColors=true}

local function isHitboxPart(obj)
    if SKIP[obj.ClassName] then return false end
    if SKIP_NAMES[obj.Name] then return false end
    if obj.Size.Magnitude<0.1 then return false end
    local par=obj.Parent
    if par and(par:IsA("Accessory")or par:IsA("Hat")or par:IsA("Tool"))then return false end
    local mesh=obj:FindFirstChildOfClass("SpecialMesh")
    if mesh and mesh.MeshType==Enum.MeshType.FileMesh and mesh.TextureId~="" then return false end
    return true
end

local function applyPart(part,pname,base)
    if not origSz[part] then
        origSz[part]=part.Size
        origTr[part]=part.Transparency
        origMat[part]=part.Material
    end
    local sz=(CFG.partSizes[pname] or base)
    if CFG.jitter then sz=math.max(1,sz+(math.random()*CFG.jitterAmt*2-CFG.jitterAmt)) end
    local st=pState[part]
    if st and st.sz==sz and st.op==CFG.opacity and st.c==CFG.color then return end
    part.Size=Vector3.new(sz,sz,sz)
    part.CanCollide=false
    pcall(function() part.CanQuery=true end)
    pcall(function() part.CanTouch=false end)
    if CFG.opacity<=0 then
        part.Transparency=1
        pcall(function() part.LocalTransparencyModifier=0 end)
        pcall(function() if sethiddenproperty then sethiddenproperty(part,"LocalTransparencyModifier",0) end end)
        task.delay(0.05,function() pcall(function() if part and part.Parent then part.Transparency=1 end end) end)
        rmBox(part)
    else
        part.Color=CFG.color
        part.Material=Enum.Material.Neon
        part.Transparency=1-CFG.opacity
        pcall(function() part.LocalTransparencyModifier=0 end)
        pcall(function() if sethiddenproperty then sethiddenproperty(part,"LocalTransparencyModifier",0) end end)
        task.delay(0.05,function() pcall(function() if part and part.Parent then part.Transparency=1-CFG.opacity end end) end)
        if CFG.showBoxes then addBox(part) else rmBox(part) end
    end
    pState[part]={sz=sz,op=CFG.opacity,c=CFG.color}
end

local function expandP(p)
    if not p.Character then return end
    local h=hCache[p]
    if not h or h.Health<=0 then restoreChar(p.Character);return end
    if teammate(p) then return end
    if not inAim(p) then restoreChar(p.Character);return end
    local sz=CFG.size
    for pname,on in pairs(CFG.parts) do
        local part=p.Character:FindFirstChild(pname)
        if part and part:IsA("BasePart") then
            if on then applyPart(part,pname,sz)
            elseif origSz[part] then restorePart(part) end
        end
    end
    if CFG.universalScan and not scPl[p] then
        for _,obj in ipairs(p.Character:GetDescendants()) do
            if obj:IsA("BasePart") and isHitboxPart(obj) and CFG.parts[obj.Name]==nil then
                applyPart(obj,obj.Name,sz)
            end
        end
        scPl[p]=true
    end
end

