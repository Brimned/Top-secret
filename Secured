local AC_MODULES = {
    "Hx","HxAC","Aegis","AntiCheat","Anticheat","FE_AC","Secured",
    "BanHammer","ANTICHEAT","ServerGuard","SmartAC","EasyAntiCheat","Pinkerton",
}
local AC_REMOTES = { "Report","Flag","Kick","Ban","Detect","Cheat","Log","Monitor","Punish" }

local function scanAC()
    local score, hits = 0, {}
    for _, n in ipairs(AC_MODULES) do
        if game:FindFirstChild(n, true) then
            table.insert(hits, n); score = score + 20
        end
    end
    for _, n in ipairs(AC_REMOTES) do
        local obj = game:FindFirstChild(n, true)
        if obj and (obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction")) then
            score = score + 8
        end
    end
    local desc = #game:GetDescendants()
    if desc > 3000  then score = score + 10 end
    if desc > 6000  then score = score + 15 end
    if desc > 10000 then score = score + 15 end
    score = math.min(score, 100)
    local lbl, icon
    if    score == 0   then lbl, icon = "Clean",     "🟢"
    elseif score <= 20 then lbl, icon = "Very Low",  "🟢"
    elseif score <= 40 then lbl, icon = "Low",       "🟡"
    elseif score <= 60 then lbl, icon = "Medium",    "🟠"
    elseif score <= 80 then lbl, icon = "High",      "🔴"
    else                    lbl, icon = "Very High", "🔴"
    end
    return icon.." "..lbl.." ("..score.."/100)", (#hits>0 and table.concat(hits,", ") or "None"), score
end

