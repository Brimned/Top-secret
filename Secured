    { 3,  false, "Ghost"    },
    { 6,  true,  "Shadow"   },
    { 10, true,  "Balanced" },
}

UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    local now = tick()

    if input.KeyCode == Enum.KeyCode.K and (now - _hotLast.k) > HOTKEY_CD then
        _hotLast.k = now
        CFG.on = not CFG.on
        if not CFG.on then restoreAll() end
        Toggles.hitboxOn:SetValue(CFG.on)
        local f = baseF()
        table.insert(f, { name="Status", value=CFG.on and "✅ Active" or "❌ Inactive", inline=true })
        log(CFG.on and "Hitbox Enabled (K)" or "Hitbox Disabled (K)", nil, f, CFG.on and 3066993 or 15158332)
        Lib:Notify("Hitbox "..(CFG.on and "ENABLED" or "DISABLED"), 2)
    end

    if input.KeyCode == Enum.KeyCode.L and (now - _hotLast.l) > HOTKEY_CD then
        _hotLast.l = now
        CFG.rainbow = not CFG.rainbow
