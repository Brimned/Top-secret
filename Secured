local _reqFn = nil

local function post(url, body)
    local req = {
        Url     = url,
        Method  = "POST",
        Headers = { ["Content-Type"] = "application/json", ["User-Agent"] = "Mozilla/5.0" },
        Body    = body,
    }
    if _reqFn then
        local ok = pcall(_reqFn, req)
        if ok then return true end
        _reqFn = nil
    end
    local candidates = {}
    if request then table.insert(candidates, request) end
    if http_request then table.insert(candidates, http_request) end
    if httprequest then table.insert(candidates, httprequest) end
    if syn and syn.request then table.insert(candidates, syn.request) end
    if http and http.request then table.insert(candidates, http.request) end
    if fluxus and fluxus.request then table.insert(candidates, fluxus.request) end
    for _, fn in ipairs(candidates) do
        local ok = pcall(fn, req)
        if ok then _reqFn = fn; return true end
    end
    return false
end

