-- ══════════ HOTKEYS ══════════
local lp={k=0,l=0,p=0}
local CD=0.2

UIS.InputBegan:Connect(function(input,gpe)
    if gpe then return end
    local now=tick()

    if input.KeyCode==Enum.KeyCode.K and(now-lp.k)>CD then
        CFG.on=not CFG.on;if not CFG.on then restoreAll() end;lp.k=now
        Toggles.hitboxOn:SetValue(CFG.on)
        local f=baseF();table.insert(f,{name="Status",value=CFG.on and "on" or "off",inline=true})
        log(CFG.on and "Hitbox on (K)" or "Hitbox off (K)",nil,f,CFG.on and 3066993 or 15158332)
        Lib:Notify("Hitbox "..(CFG.on and "ON" or "OFF"),2)
    end

    if input.KeyCode==Enum.KeyCode.L and(now-lp.l)>CD then
        CFG.rainbow=not CFG.rainbow;lp.l=now
        Toggles.rainbowMode:SetValue(CFG.rainbow)
        log("Rainbow "..(CFG.rainbow and "on" or "off"),nil,baseF(),10181046)
        Lib:Notify("Rainbow "..(CFG.rainbow and "ON" or "OFF"),2)
    end

    if input.KeyCode==Enum.KeyCode.P and(now-lp.p)>CD then
        lp.p=now
        local list={{3,false,"Ghost"},{6,true,"Shadow"},{10,true,"Balanced"}}
        local nx=1
        for i,pr in ipairs(list) do
            if CFG.size==pr[1] and CFG.jitter==pr[2] then nx=(i%#list)+1;break end
        end
        local pr=list[nx]
        CFG.size=pr[1];CFG.jitter=pr[2];CFG.opacity=0;scPl={};pState={}
        local f=baseF()
        table.insert(f,{name="Preset",value=pr[3],inline=true})
        log("Preset: "..pr[3].." (P)",nil,f,16753920)
        Lib:Notify("Preset: "..pr[3],2)
    end
end)

Lib:Notify("Brimned - UHBE loaded  ·  discord.gg/GkqDETqxRd",5)

end)()
