local function runTest(dur)
    if CFG.testActive then return end
    CFG.testActive = true
    local savedOn = CFG.on
    local savedBx = CFG.showBoxes
    local savedOp = CFG.opacity
    CFG.on = true; CFG.showBoxes = true; CFG.opacity = 0.7; pStyle = setmetatable({}, WEAK_META)
    log2("🧪 Test Mode Initiated", "Visualization active for "..dur.." seconds", baseF(), 3066993)
    Lib:Notify("Test Mode Active\nHitboxes visible for "..dur.."s", dur+1)
    task.delay(dur, function()
        CFG.on        = savedOn
        CFG.showBoxes = savedBx
        CFG.opacity   = savedOp
        pStyle        = setmetatable({}, WEAK_META)
        if not savedOn then restoreAll() end
        if not savedBx then clearBoxes() end
        CFG.testActive = false
        pcall(function() Toggles.hitboxOn:SetValue(savedOn) end)
        log2("🧪 Test Mode Concluded", "Restored previous settings after "..dur.."s", baseF(), 7506394)
        Lib:Notify("Test Mode Ended\nSettings restored", 3)
    end)
end

