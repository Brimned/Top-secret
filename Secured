local function loadCFG(name)
    if name == "" then return false end
    local ok, d = pcall(function()
        return HttpSvc:JSONDecode(readfile(FOLDER .. "/" .. name .. ".json"))
    end)
    if not ok or not d then return false end
    if d.size      then CFG.size      = d.size      end
    if d.opacity   ~= nil then CFG.opacity   = d.opacity   end
    if d.rainbow   ~= nil then CFG.rainbow   = d.rainbow   end
    if d.jitter    ~= nil then CFG.jitter    = d.jitter    end
    if d.jitterAmt then CFG.jitterAmt = d.jitterAmt end
    if d.aimGate   ~= nil then CFG.aimGate   = d.aimGate   end
    if d.aimFOV    then CFG.aimFOV    = d.aimFOV    end
    if d.teamSkip  ~= nil then CFG.teamSkip  = d.teamSkip  end
    if d.showBoxes ~= nil then CFG.showBoxes = d.showBoxes end
    if d.colorHex  then local c = hex2c3(d.colorHex); if c then CFG.color = c end end
    if d.parts     then for k, v in pairs(d.parts)     do CFG.parts[k]     = v end end
    if d.partSizes then for k, v in pairs(d.partSizes) do CFG.partSizes[k] = v end end
    return true
end

-- ══════════════════════════════════════
--   SELECTION BOXES
-- ══════════════════════════════════════
local selBoxes  = {}
local boxColors = {}

local function rmBox(part)
    local bx = selBoxes[part]
    if not bx then return end
    pcall(function() bx:Destroy() end)
    boxColors[bx]   = nil
    selBoxes[part]  = nil
end

local function addBox(part)
    rmBox(part)
    if not CFG.showBoxes then return end
    local ok, bx = pcall(function()
        local b = Instance.new("SelectionBox")
        b.Adornee             = part
        b.Color3              = CFG.color
        b.LineThickness       = 0.05
        b.SurfaceColor3       = CFG.color
        b.SurfaceTransparency = 0.6
        b.Parent              = part
        boxColors[b]          = CFG.color
        return b
    end)
    if ok then selBoxes[part] = bx end
end

local function clearBoxes()
    for part in pairs(selBoxes) do rmBox(part) end
end

local function refreshBoxColors()
    for part, bx in pairs(selBoxes) do
        if bx and bx.Parent then
            if boxColors[bx] ~= CFG.color then
                bx.Color3        = CFG.color
                bx.SurfaceColor3 = CFG.color
                boxColors[bx]    = CFG.color
            end
        else
            selBoxes[part] = nil
        end
    end
end

-- ══════════════════════════════════════
--   PART STATE
-- ══════════════════════════════════════
local origSz   = {}   -- [part] = original Vector3 Size
local origTr   = {}   -- [part] = original Transparency
local origMat  = {}   -- [part] = original Material
local scPl     = {}   -- [player] = true  (universal scan done this life)
local pStyle   = {}   -- [part] = { op, c }  last written style
local hCache   = {}   -- [player] = Humanoid
local charParts = {}  -- [char] = { [part]=true }  for fast char restore

local _frame = 0
local TFRAME = 4      -- process every 4th heartbeat (~15/s) — smooth enough, much lighter

local function _trackPart(part, char)
    if not charParts[char] then charParts[char] = {} end
    charParts[char][part] = true
end

local function restorePart(part)
    if not part then return end
    if part.Parent then
        if origSz[part]    then part.Size = origSz[part] end
        if origTr[part] ~= nil then part.Transparency = origTr[part] end
        if origMat[part]   then pcall(function() part.Material = origMat[part] end) end
    end
    rmBox(part)
    origSz[part]  = nil
    origTr[part]  = nil
    origMat[part] = nil
    pStyle[part]  = nil
end

local function restoreChar(char)
    if not char then return end
    local idx = charParts[char]
    if idx then
        for part in pairs(idx) do restorePart(part) end
        charParts[char] = nil
    else
        for part in pairs(origSz) do
            if part and part.Parent and part:IsDescendantOf(char) then
                restorePart(part)
            end
        end
    end
    local pl = Players:GetPlayerFromCharacter(char)
    if pl then scPl[pl] = nil end
end

local function restoreAll()
    local snapshot = {}
    for part in pairs(origSz) do table.insert(snapshot, part) end
    for _, part in ipairs(snapshot) do restorePart(part) end
    clearBoxes()
    scPl      = {}
    pStyle    = {}
    origMat   = {}
    charParts = {}
end

