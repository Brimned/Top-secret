local function hookDied(p)
    if hookedDied[p] then hookedDied[p]:Disconnect() end
    hookedDied[p] = nil
    if not p.Character then return end
    local h = p.Character:FindFirstChildOfClass("Humanoid")
    if not h then return end
    hookedDied[p] = h.Died:Connect(function()
        onPlayerDied(p)
    end)
end

local function restorePart(p)
    if not p or not p.Parent then return end
    if origSz[p]    then p.Size=origSz[p] end
    if origTr[p]~=nil then p.Transparency=origTr[p] end
    if origMat[p]   then pcall(function() p.Material=origMat[p] end) end
    p.CanCollide=false;rmBox(p)
    origSz[p]=nil;origTr[p]=nil;origMat[p]=nil;pState[p]=nil
end

local function restoreChar(char)
    if not char then return end
    for p in pairs(origSz) do
        if p and p.Parent and p:IsDescendantOf(char) then restorePart(p) end
    end
    local pl=Players:GetPlayerFromCharacter(char)
    if pl then exPl[pl]=nil;scPl[pl]=nil end
end

local function restoreAll()
    local t={}
    for p in pairs(origSz) do if p and p.Parent then table.insert(t,p) end end
    for _,p in ipairs(t) do restorePart(p) end
    clearBoxes();exPl={};scPl={};pState={};origMat={}
end

