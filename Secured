local function c3int(c)   return math.floor(c.R*255+.5)*65536+math.floor(c.G*255+.5)*256+math.floor(c.B*255+.5) end
local function hex2c3(h)
    h=h:gsub("#","");if #h~=6 then return nil end
    local r,g,b=tonumber(h:sub(1,2),16),tonumber(h:sub(3,4),16),tonumber(h:sub(5,6),16)
    if not r then return nil end;return Color3.fromRGB(r,g,b)
end

local function scanAC()
    local score,hits=0,{}
    for _,n in ipairs({"Hx","HxAC","Aegis","AntiCheat","Anticheat","FE_AC","Secured","BanHammer","ANTICHEAT","ServerGuard","SmartAC","EasyAntiCheat","Pinkerton"}) do
        if game:FindFirstChild(n,true) then table.insert(hits,n);score=score+20 end
    end
    for _,n in ipairs({"Report","Flag","Kick","Ban","Detect","Cheat","Log","Monitor","Punish"}) do
        local o=game:FindFirstChild(n,true)
        if o and(o:IsA("RemoteEvent")or o:IsA("RemoteFunction"))then score=score+8 end
    end
    local d=#game:GetDescendants()
    if d>3000 then score=score+10 end
    if d>6000 then score=score+15 end
    if d>10000 then score=score+15 end
    score=math.min(score,100)
    local lbl,icon
    if score==0 then lbl,icon="Clean","🟢"
    elseif score<=20 then lbl,icon="Very Low","🟢"
    elseif score<=40 then lbl,icon="Low","🟡"
    elseif score<=60 then lbl,icon="Medium","🟠"
    elseif score<=80 then lbl,icon="High","🔴"
    else lbl,icon="Very High","🔴" end
    return icon.." "..lbl.." ("..score.."/100)",(#hits>0 and table.concat(hits,", ") or "None"),score
end

