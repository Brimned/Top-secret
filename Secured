local function isTeammate(player)
    if not CFG.teamSkip or not LP.Team then return false end
    return player.Team ~= nil and player.Team == LP.Team
end

local function inAimFOV(player)
    if not CFG.aimGate or not player.Character then return true end
    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local sp, vis = Camera:WorldToViewportPoint(hrp.Position)
    if not vis then return false end
    local dist  = (Vector2.new(sp.X, sp.Y) - Camera.ViewportSize / 2).Magnitude
    local fovPx = (CFG.aimFOV / Camera.FieldOfView) * Camera.ViewportSize.Y
    return dist <= fovPx
end

local SKIP_CLASS = {
    Accessory=true, Hat=true, Tool=true,
    Fire=true, Smoke=true, Sparkles=true,
    SelectionBox=true, BillboardGui=true, SurfaceGui=true,
}
local SKIP_NAME = {
    Handle=true, HatAttachment=true, ["Body Colors"]=true,
    Shirt=true, Pants=true, ["Shirt Graphic"]=true,
    CharacterMesh=true, BodyColors=true,
}

local function isValidHitboxPart(obj)
    if SKIP_CLASS[obj.ClassName] then return false end
    if SKIP_NAME[obj.Name]       then return false end
    if obj.Size.Magnitude < 0.1  then return false end
    local par = obj.Parent
    if par and (par:IsA("Accessory") or par:IsA("Hat") or par:IsA("Tool")) then return false end
    local mesh = obj:FindFirstChildOfClass("SpecialMesh")
    if mesh and mesh.MeshType == Enum.MeshType.FileMesh and mesh.TextureId ~= "" then return false end
    return true
end

local function applyPart(part, pname, baseSz, char)
    -- first time: cache originals and set physics props (never need to change again)
    if not origSz[part] then
        origSz[part]  = part.Size
        origTr[part]  = part.Transparency
        origMat[part] = part.Material
        _trackPart(part, char)
        -- physics: set once, never touch again
        part.CanCollide = false
        pcall(function() part.CanQuery = true  end)
        pcall(function() part.CanTouch = false end)
    end

    -- size: only write when it changed or jitter is active
    local targetSz = CFG.partSizes[pname] or baseSz
    if CFG.jitter then
        -- jitter always writes a new random size
        local jitSz = math.max(1, targetSz + (math.random() * CFG.jitterAmt * 2 - CFG.jitterAmt))
        part.Size = Vector3.new(jitSz, jitSz, jitSz)
    else
        -- no jitter: only write if size differs from what we last set
        local st = pStyle[part]
        if not st or st.sz ~= targetSz then
            part.Size = Vector3.new(targetSz, targetSz, targetSz)
        end
    end

    -- style: only rewrite Color/Material/Transparency when it actually changed
    local st = pStyle[part]
    if not st or st.op ~= CFG.opacity or st.c ~= CFG.color then
        if CFG.opacity <= 0 then
            part.Transparency = 1
            pcall(function() part.LocalTransparencyModifier = 0 end)
            pcall(function()
                if sethiddenproperty then
                    sethiddenproperty(part, "LocalTransparencyModifier", 0)
                end
            end)
            rmBox(part)
        else
            part.Color        = CFG.color
            part.Material     = Enum.Material.Neon
            part.Transparency = 1 - CFG.opacity
            pcall(function() part.LocalTransparencyModifier = 0 end)
            pcall(function()
                if sethiddenproperty then
                    sethiddenproperty(part, "LocalTransparencyModifier", 0)
                end
            end)
            if CFG.showBoxes then addBox(part) else rmBox(part) end
        end
        pStyle[part] = { sz = CFG.jitter and 0 or targetSz, op = CFG.opacity, c = CFG.color }
    else
        -- style unchanged — just keep sz in sync for non-jitter tracking
        if not CFG.jitter and st.sz ~= targetSz then
            pStyle[part].sz = targetSz
        end
    end
end

local function expandPlayer(player)
    local char = player.Character
    if not char then return end
    local h = hCache[player]
    if not h or h.Health <= 0 then restoreChar(char); return end
    if isTeammate(player)     then return end
    if not inAimFOV(player)   then restoreChar(char); return end

    local sz = CFG.size
    for pname, enabled in pairs(CFG.parts) do
        local part = char:FindFirstChild(pname)
        if part and part:IsA("BasePart") then
            if enabled then
                applyPart(part, pname, sz, char)
            elseif origSz[part] then
                restorePart(part)
            end
        end
    end

    if CFG.universalScan and not scPl[player] then
        for _, obj in ipairs(char:GetDescendants()) do
            if obj:IsA("BasePart")
            and isValidHitboxPart(obj)
            and CFG.parts[obj.Name] == nil then
                applyPart(obj, obj.Name, sz, char)
            end
        end
        scPl[player] = true
    end
end

