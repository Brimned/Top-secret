local function loadCFG(name)
    if name=="" then return false end
    local ok,d=pcall(function() return HttpSvc:JSONDecode(readfile(FOLDER.."/"..name..".json")) end)
    if not ok or not d then return false end
    CFG.size=d.size or CFG.size
    CFG.opacity=d.opacity~=nil and d.opacity or CFG.opacity
    CFG.rainbow=d.rainbow~=nil and d.rainbow or false
    CFG.jitter=d.jitter~=nil and d.jitter or false
    CFG.jitterAmt=d.jitterAmt or CFG.jitterAmt
    CFG.aimGate=d.aimGate~=nil and d.aimGate or false
    CFG.aimFOV=d.aimFOV or CFG.aimFOV
    CFG.teamSkip=d.teamSkip~=nil and d.teamSkip or false
    CFG.showBoxes=d.showBoxes~=nil and d.showBoxes or false
    if d.colorHex then local c=hex2c3(d.colorHex);if c then CFG.color=c end end
    if d.parts then for k,v in pairs(d.parts) do CFG.parts[k]=v end end
    if d.partSizes then for k,v in pairs(d.partSizes) do CFG.partSizes[k]=v end end
    return true
end

local selBoxes,boxColors={},{}
local function rmBox(p)
    if selBoxes[p] then pcall(function() selBoxes[p]:Destroy() end);selBoxes[p]=nil end
