--   HOTKEYS
-- ══════════════════════════════════════
local _hotLast  = { k=0, r=0, p=0 }
local HOTKEY_CD = 0.25

local PRESET_CYCLE = {
    { 3,  false, "Ghost"    },
    { 6,  true,  "Shadow"   },
    { 10, true,  "Balanced" },
}

UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    local now = tick()

    if input.KeyCode == Enum.KeyCode.K and (now - _hotLast.k) > HOTKEY_CD then
        _hotLast.k = now
        CFG.on = not CFG.on
        if not CFG.on then restoreAll() end
        Toggles.hitboxOn:SetValue(CFG.on)
        local f = baseF()
        table.insert(f, { name="Status", value=CFG.on and "on" or "off", inline=true })
        log(CFG.on and "Hitbox on (K)" or "Hitbox off (K)", nil, f, CFG.on and 3066993 or 15158332)
        Lib:Notify("Hitbox "..(CFG.on and "ON" or "OFF"), 2)
    end

    if input.KeyCode == Enum.KeyCode.R and (now - _hotLast.r) > HOTKEY_CD then
        _hotLast.r = now
        CFG.rainbow = not CFG.rainbow
        Toggles.rainbowMode:SetValue(CFG.rainbow)
        log("Rainbow "..(CFG.rainbow and "on" or "off"), nil, baseF(), 10181046)
        Lib:Notify("Rainbow "..(CFG.rainbow and "ON" or "OFF"), 2)
    end

    if input.KeyCode == Enum.KeyCode.P and (now - _hotLast.p) > HOTKEY_CD then
        _hotLast.p = now
        local nx = 1
        for i, pr in ipairs(PRESET_CYCLE) do
            if CFG.size == pr[1] and CFG.jitter == pr[2] then
                nx = (i % #PRESET_CYCLE) + 1; break
            end
        end
        local pr = PRESET_CYCLE[nx]
        applyPreset(pr[1], pr[2], {"HumanoidRootPart"}, nil, pr[3], "hotkey")
        Lib:Notify("Preset: "..pr[3], 2)
    end
end)

