local function autoSafe(acScore, ac)
    if acScore >= 80 then
        CFG.on = false
        pcall(function() Toggles.hitboxOn:SetValue(false) end)
        applyPreset(3, true, {"HumanoidRootPart"}, nil, "Ghost", "auto-safe")
        restoreAll()
        Lib:Notify("⛔ VERY HIGH AC — hitbox disabled for safety", 9)
    elseif acScore >= 60 then
        applyPreset(3, true, {"HumanoidRootPart"}, nil, "Ghost", "auto-safe")
        Lib:Notify("⚠️ High AC ("..ac..") — switched to Ghost preset", 8)
    elseif acScore >= 40 then
        Lib:Notify("🟡 AC detected — keep sizes small", 6)
    end
end

