local PM =Tabs.Main:AddLeftGroupbox("Presets")
local PM2=Tabs.Main:AddRightGroupbox("Presets cont.")

local function preset(sz,jit,partSet,col,name,tip)
    CFG.size=sz;CFG.jitter=jit;CFG.opacity=0
    if partSet then
        for k in pairs(CFG.parts) do CFG.parts[k]=false end
        for _,k in ipairs(partSet) do CFG.parts[k]=true end
    end
    if col then
        CFG.color=col;CFG.rainbow=false
        for p in pairs(origSz) do if p and p.Parent then pcall(function() p.Color=CFG.color end) end end
        refreshBoxes()
    end
    pState={};scPl={}
    local f=baseF()
    table.insert(f,{name="Preset",value=name,inline=true})
    table.insert(f,{name="Size",value=sz.."s",inline=true})
    log("Preset: "..name,tip,f,16753920)
    Lib:Notify(name.." — "..tip,3)
end

