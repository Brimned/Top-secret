local function addBox(p)
    rmBox(p);if not CFG.showBoxes then return end
    local ok,b=pcall(function()
        local bx=Instance.new("SelectionBox")
        bx.Adornee=p;bx.Color3=CFG.color;bx.LineThickness=0.05
        bx.SurfaceColor3=CFG.color;bx.SurfaceTransparency=0.6;bx.Parent=p
        boxColors[bx]=CFG.color;return bx
    end);if ok then selBoxes[p]=b end
end
local function clearBoxes() for p in pairs(selBoxes) do rmBox(p) end end
local function refreshBoxes()
    for _,b in pairs(selBoxes) do pcall(function()
        if b and b.Parent and boxColors[b]~=CFG.color then
            b.Color3=CFG.color;b.SurfaceColor3=CFG.color;boxColors[b]=CFG.color
        end
    end) end
end

